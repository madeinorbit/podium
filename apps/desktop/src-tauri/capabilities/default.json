{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Podium desktop default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:webview:allow-create-webview-window",
    "updater:default",
    "dialog:default",
    "process:default",
    "process:allow-restart",
    "sql:default",
    "sql:allow-execute"
  ]
}
