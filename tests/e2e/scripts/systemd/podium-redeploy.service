[Unit]
Description=Podium redeploy — restart backend + web to run the latest main (triggered by git HEAD change)
# Triggered by podium-redeploy.path on .git/logs/HEAD changes. The backend runs from
# source, so a restart picks up newly-merged code. The web Vite dev server must
# restart too: its long-lived module graph has gone stale across merges twice
# (stale @podium/protocol 2026-06-11; stale SocketHub/"hub.onAttention is not a
# function" 2026-06-12) — HMR does not reliably survive large git-driven rewrites.
After=podium-backend.service

[Service]
Type=oneshot
ExecStart=/usr/bin/systemctl --user restart podium-backend.service podium-web.service
