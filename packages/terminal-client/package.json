{
  "name": "@podium/terminal-client",
  "version": "0.0.0",
  "private": true,
  "description": "Browser presentation client for Podium agent terminal sessions: xterm.js rendering, mobile key toolbar, touch/scroll policy, reconnect, multi-client, transcript view.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@podium/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./connection": {
      "@podium/source": "./src/connection.ts",
      "types": "./src/connection.ts",
      "import": "./src/connection.ts"
    },
    "./session-mount": {
      "@podium/source": "./src/session-mount.ts",
      "types": "./src/session-mount.ts",
      "import": "./src/session-mount.ts"
    },
    "./terminal-view": {
      "@podium/source": "./src/terminal-view.ts",
      "types": "./src/terminal-view.ts",
      "import": "./src/terminal-view.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@podium/composer": "workspace:*",
    "@podium/protocol": "workspace:*",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^6.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsgo --noEmit",
    "typecheck:tsc": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "5.0.0-beta.6"
  }
}
