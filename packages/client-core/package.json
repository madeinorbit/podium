{
  "name": "@podium/client-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "@podium/source": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./focus": {
      "@podium/source": "./src/focus.ts",
      "types": "./src/focus.ts",
      "import": "./src/focus.ts"
    },
    "./transport": {
      "@podium/source": "./src/transport.ts",
      "types": "./src/transport.ts",
      "import": "./src/transport.ts"
    },
    "./outbox": {
      "@podium/source": "./src/outbox.ts",
      "types": "./src/outbox.ts",
      "import": "./src/outbox.ts"
    },
    "./store": {
      "@podium/source": "./src/store.ts",
      "types": "./src/store.ts",
      "import": "./src/store.ts"
    },
    "./viewmodels": {
      "@podium/source": "./src/viewmodels/index.ts",
      "types": "./src/viewmodels/index.ts",
      "import": "./src/viewmodels/index.ts"
    },
    "./replica": {
      "@podium/source": "./src/replica/index.ts",
      "types": "./src/replica/index.ts",
      "import": "./src/replica/index.ts"
    },
    "./router": {
      "@podium/source": "./src/router.ts",
      "types": "./src/router.ts",
      "import": "./src/router.ts"
    },
    "./api": {
      "@podium/source": "./src/api.ts",
      "types": "./src/api.ts",
      "import": "./src/api.ts"
    },
    "./react": {
      "@podium/source": "./src/react/index.ts",
      "types": "./src/react/index.ts",
      "import": "./src/react/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@podium/protocol": "workspace:*",
    "@podium/core": "workspace:*",
    "@podium/terminal-client": "workspace:*",
    "@tanstack/db": "^0.6.14",
    "@tanstack/react-db": "^0.1.92"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "@types/react": "^19.0.0",
    "react": "19.2.7"
  },
  "peerDependencies": {
    "react": ">=19"
  }
}
