{
  "name": "podium",
  "private": true,
  "version": "0.1.1",
  "description": "Mission control for coding agents \u2014 run, observe, and steer Claude Code, Codex, and other agent CLIs from one self-hosted web UI.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/madeinorbit/podium#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madeinorbit/podium.git"
  },
  "bugs": {
    "url": "https://github.com/madeinorbit/podium/issues"
  },
  "keywords": [
    "ai-agents",
    "claude-code",
    "codex",
    "coding-agents",
    "developer-tools",
    "terminal",
    "self-hosted"
  ],
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=22",
    "bun": ">=1.3.5"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*",
    "tests/*"
  ],
  "scripts": {
    "build": "bun run --filter './packages/*' build",
    "dev": "bun run --filter './packages/*' dev",
    "host": "bun run --filter @podium/web dev & bun --conditions=@podium/source --watch scripts/host.ts",
    "host:web": "bun run --filter @podium/web dev",
    "host:backend": "bun --conditions=@podium/source --watch scripts/host.ts",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run test:unit && bun run test:web && bun run test:bun:unit",
    "test:unit": "bun --bun vitest run --passWithNoTests --config vitest.unit.config.ts --project node",
    "test:web": "bun run --cwd apps/web test:unit",
    "test:integration": "bun --bun vitest run --passWithNoTests --config vitest.integration.config.ts",
    "test:smoke:agents": "PODIUM_REAL_CLI=1 bun --bun vitest run --passWithNoTests --config vitest.agent-smoke.config.ts",
    "test:e2e": "NODE_OPTIONS=--conditions=@podium/source bun --bun vitest run --config vitest.integration.config.ts tests/e2e",
    "test:multi-instance": "bun test --conditions=@podium/source ./scripts/multi-instance-runtime.integration.bun.test.ts && bun --bun vitest run scripts/managed-account-spawn.integration.test.ts && bash scripts/install-sh.test.sh",
    "test:bun": "bun test --conditions=@podium/source apps/daemon/test packages/runtime/test/sqlite.bun.test.ts scripts/lifecycle.integration.bun.test.ts --test-name-pattern ''",
    "test:bun:unit": "bun test --conditions=@podium/source packages/runtime/test/sqlite.bun.test.ts --test-name-pattern ''",
    "lint": "biome check . && bun run lint:boundaries && bun scripts/render-systemd.ts --check",
    "lint:boundaries": "bun scripts/check-boundaries.ts",
    "format": "biome format --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run build && changeset publish",
    "package:headless": "bun run --filter @podium/web build && bun scripts/build-bun.ts",
    "desktop:build": "bun run --cwd apps/desktop build",
    "migration:new": "bun run scripts/new-migration.ts",
    "migration:check": "drizzle-kit check",
    "migration:manifest": "bun run scripts/build-drizzle-manifest.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.60.0",
    "drizzle-kit": "1.0.0-rc.4",
    "drizzle-orm": "1.0.0-rc.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "happy-dom": "^20.10.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "5.0.0-beta.6"
  },
  "patchedDependencies": {
    "@xterm/addon-web-links@0.11.0": "patches/@xterm%2Faddon-web-links@0.11.0.patch"
  }
}
