{
  "name": "podium",
  "private": true,
  "version": "0.1.1",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=22",
    "bun": ">=1.3.5"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*",
    "tests/*"
  ],
  "scripts": {
    "build": "bun run --filter './packages/*' build",
    "dev": "bun run --filter './packages/*' dev",
    "host": "bun run --filter @podium/web dev & bun --conditions=@podium/source --watch scripts/host.ts",
    "host:web": "bun run --filter @podium/web dev",
    "host:backend": "bun --conditions=@podium/source --watch scripts/host.ts",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "vitest run --passWithNoTests && bun run test:bun",
    "test:bun": "bun test --conditions=@podium/source apps/daemon/test packages/runtime/test/sqlite.bun.test.ts scripts/lifecycle.integration.bun.test.ts --test-name-pattern ''",
    "lint": "biome check . && bun run lint:boundaries",
    "lint:boundaries": "bun scripts/check-boundaries.ts",
    "format": "biome format --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run build && changeset publish",
    "package:headless": "bun run --filter @podium/web build && bun scripts/build-bun.ts",
    "desktop:build": "bun run --cwd apps/desktop build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "happy-dom": "^20.10.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "patchedDependencies": {
    "@xterm/addon-web-links@0.11.0": "patches/@xterm%2Faddon-web-links@0.11.0.patch"
  }
}
