{
  "name": "podium",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=22",
    "bun": ">=1.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*",
    "tests/*"
  ],
  "scripts": {
    "build": "bun run --filter './packages/*' build",
    "dev": "bun run --filter './packages/*' dev",
    "host": "bun run --filter @podium/web dev & node_modules/.bin/tsx watch scripts/host.ts",
    "host:web": "bun run --filter @podium/web dev",
    "host:backend": "node_modules/.bin/tsx watch scripts/host.ts",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "vitest run --passWithNoTests",
    "lint": "biome check .",
    "format": "biome format --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "happy-dom": "^20.10.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
